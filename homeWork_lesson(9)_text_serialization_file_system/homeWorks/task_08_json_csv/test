from datetime import datetime
import json
import os
import pandas as pd

def add_employee_and_sync(json_path: str, csv_path: str) -> None:
    """Запрашивает данные сотрудника, пишет в JSON и сразу синхронизирует с CSV."""
    print("--- Ввод данных нового сотрудника ---")

    # 1. Сбор и валидация данных
    name = input("Введите имя и фамилию: ").strip()

    # Валидация даты рождения
    birthday = get_validated_date(
        "Введите дату рождения (формат ДД.ММ.ГГГГ): "
    )

    # Валидация числовых значений
    while True:
        try:
            height = int(input("Введите рост (см): "))
            weight = float(input("Введите вес (кг): "))
            break
        except ValueError:
            print(
                "Ошибка: Рост должен быть целым числом, а вес — числом с точкой!"
            )

    # Логический тип
    car_input = (
        input("Есть ли автомобиль? (да/нет): ").strip().lower()
    )
    car = car_input in ["да", "yes", "y", "1"]

    # Список
    langs_input = input(
        "Введите языки programming через запятую: "
    )
    languages = [
        lang.strip() for lang in langs_input.split(",") if lang.strip()
    ]

    # Создаем структуру объекта
    new_employee = {
        "name": name,
        "birthday": birthday,
        "height": height,
        "weight": weight,
        "car": car,
        "languages": languages,
    }

    # 2. Чтение текущего JSON-файла
    if os.path.exists(json_path) and os.path.getsize(json_path) > 0:
        with open(json_path, "r", encoding="utf-8") as f:
            try:
                data = json.load(f)
                if not isinstance(data, list):
                    data = [data]
            except json.JSONDecodeError:
                data = []
    else:
        data = []

    # 3. Запись обновленных данных в JSON
    data.append(new_employee)
    with open(json_path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=4)
    print(f"\nСотрудник {name} добавлен в '{json_path}'.")

    # 4. Автоматический экспорт в CSV
    update_csv_from_json(json_path, csv_path)
